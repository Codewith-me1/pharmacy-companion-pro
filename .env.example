# Copy this file to .env and fill in your values.

# Required for AI-powered purchase invoice OCR (Purchase Entry module).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for AI-powered purchase invoice OCR (Purchase Entry module). The invoice photo is
# first sent to Azure Document Intelligence's prebuilt-layout model to get accurate OCR text and
# table row/column structure; that structured text (not the raw photo) is then handed to ChatGPT
# for semantic field mapping. Create a "Document Intelligence" resource in the Azure portal to get
# these two values (Keys and Endpoint blade).
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Optional. Model used for the ChatGPT semantic-mapping step above. Defaults to gpt-4o if unset.
OPENAI_EXTRACTION_MODEL=

# PostgreSQL connection string used for migrations (drizzle-kit) and one-off admin scripts.
# Local dev default: a Docker container named "mediOS-postgres" on port 5433
# (started with: docker run -d --name mediOS-postgres -e POSTGRES_PASSWORD=yourpass -e POSTGRES_DB=mediOS -p 5433:5432 postgres:16)
DATABASE_URL=

# Connection string for a RESTRICTED database role (no BYPASSRLS, no superuser) used by the
# running app. Required for per-tenant Row-Level Security to actually be enforced — DATABASE_URL
# (an admin role) silently bypasses RLS. See src/lib/db/tenant.server.ts for why this matters.
APP_DATABASE_URL=

# Secret used to sign/encrypt the login session cookie. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
